<Window x:Class="PCDiagnostic.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sobre PCDiagnostic"        
        Height="650"
        Width="900"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0F1117"
        Foreground="White">

    <Grid>

        <StackPanel Margin="25">

            <!-- Títol -->

            <Image Source="/Assets/pcdagnostic.ico"
                    Width="48"
                    Height="48"
                    HorizontalAlignment="Center"
                    Margin="0,10,0,15"/>

            <TextBlock Text="PCDiagnostic"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"/>

            <TextBlock Text="Versió Beta 1.0"
                       FontSize="12"
                       Foreground="#3B82F6"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,15"/>

            <!-- Descripció -->

            <Border Background="#161A22"
                    CornerRadius="15"
                    Padding="15"
                    Margin="0,0,0,15">

                <TextBlock TextWrapping="Wrap"
                           FontSize="16"
                           TextAlignment="Center">
                            PCDiagnostic ajuda a detectar problemes,
                            analitzar el rendiment i generar informes
                            complets del sistema Windows.
                </TextBlock>

            </Border>

            <!-- Contacte + Serveis -->

            <Grid Margin="0,0,0,30">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- CONTACTE -->

                <Border Grid.Column="0"
                        Background="#161A22"
                        CornerRadius="15"
                        Padding="12">

                    <StackPanel>

                        <TextBlock Text="👤 CONTACTE"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#3B82F6"
                                   Margin="0,0,0,20"/>

                        <TextBlock Text="INFORMATICASSA"
                                   FontWeight="Bold"
                                   FontSize="18"
                                   Foreground="White"/>

                        <TextBlock Text="👨 Miquel Fajardo"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="✉ miquel.fajardo@protonmail.com"
                                   Margin="0,0,0,8"/>

                        <TextBlock>
                            <Hyperlink Click="Website_Click">
                                www.informaticassa.tailc888e4.ts.net
                            </Hyperlink>
                        </TextBlock>

                        <TextBlock Margin="0,8,0,0">
                            <Hyperlink Click="Whatsapp_Click">
                                📱 WhatsApp
                            </Hyperlink>
                        </TextBlock>


                    </StackPanel>

                </Border>

                <!-- SERVEIS -->

                <Border Grid.Column="2"
                        Background="#161A22"
                        CornerRadius="15"
                        Padding="20">

                    <StackPanel>

                        <TextBlock Text="⚙ SERVEIS"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#3B82F6"
                                   Margin="0,0,0,20"/>                   

                        <TextBlock Text="✔ Reparació i manteniment"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="✔ Migració HDD a SSD"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="✔ Còpies de seguretat"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="✔ Desenvolupament d'aplicacions"
                                    Margin="0,0,0,8"/>

                        <TextBlock Text="✔ Xarxes i WiFi"
                                   Margin="0,0,0,8"/>

                        <TextBlock Text="✔ Ciberseguretat"/>

                    </StackPanel>

                </Border>

            </Grid>

            <!-- Botó -->

            <Button Content="✖ TANCAR"
        Width="180"
        Height="40"
        Click="BtnClose_Click"
        Foreground="White"
        BorderThickness="0"
        FontWeight="SemiBold"
        Cursor="Hand">

                <Button.Template>
                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                    Background="#3B82F6"
                    CornerRadius="15">

                            <ContentPresenter
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                         Value="True">

                                <Setter TargetName="border"
                            Property="Background"
                            Value="#4F8CFF"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                         Value="True">

                                <Setter TargetName="border"
                            Property="Background"
                            Value="#2D6BEE"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Button.Template>

            </Button>


        </StackPanel>

    </Grid>

</Window>